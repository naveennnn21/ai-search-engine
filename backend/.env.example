UPLOAD_DIR=uploads
VECTOR_INDEX_DIR=storage/faiss
FAISS_INDEX_FILENAME=documents.index
VECTOR_METADATA_FILENAME=documents_metadata.json
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_SIZE_MB=25
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BASE_SECONDS=0.5
EMBEDDING_RETRY_MAX_SECONDS=8.0
EMBEDDING_RETRY_JITTER_SECONDS=0.25
LLM_MODEL=gpt-4.1-mini
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=0.5
LLM_RETRY_MAX_SECONDS=8.0
RETRIEVAL_CANDIDATE_COUNT=40
RERANK_CANDIDATE_COUNT=20
VECTOR_SEARCH_WEIGHT=0.65
BM25_SEARCH_WEIGHT=0.35
ENABLE_QUERY_EXPANSION=true
QUERY_EXPANSION_COUNT=2
ENABLE_RERANKING=true
LOG_LEVEL=INFO
